---
import { Image } from "astro:assets";

const { data } = Astro.props;
const images = data.images || [];

const allGalleryImages = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/gallery/*.{jpeg,jpg,png,gif,webp}",
);
---

<section class={`station align-${data.align || "center"}`}>
  <div class="glass-card gallery-container">
    {data.title && <h2>{data.title}</h2>}

    <div class="carousel-wrapper">
      <button class="nav-btn left-btn" aria-label="הבא">&#10095;</button>

      <div class="gallery-track">
        {
          images.map((image, index) => {
            const imagePath = `/src/assets/gallery/${image.filename}`;
            const imageFactory = allGalleryImages[imagePath];

            if (!imageFactory) {
              console.error(`Image not found: ${imagePath}`);
              return null;
            }

            return (
              <div
                class={`gallery-slide ${index === 0 ? "active" : ""}`}
                data-index={index}
              >
                <div class="image-frame">
                  <Image
                    src={imageFactory()}
                    alt={image.alt || `Gallery image ${index + 1}`}
                    class="gallery-image"
                    loading={index === 0 ? "eager" : "lazy"}
                  />
                </div>
                {image.caption && (
                  <p class="image-caption">{image.caption}</p>
                )}{" "}
              </div>
            );
          })
        }
      </div>

      <button class="nav-btn right-btn" aria-label="הקודם">&#10094;</button>
    </div>

    <div class="pagination-dots">
      {
        images.map((_, index) => (
          <button
            class={`dot ${index === 0 ? "active" : ""}`}
            aria-label={`Image ${index + 1}`}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  .station {
    height: 100dvh;
    width: 100%;
    scroll-snap-align: start;
    display: flex;
    align-items: center;
    padding: 0 10%;
    box-sizing: border-box;
    position: relative;
    z-index: 10;
  }

  .align-start {
    justify-content: flex-start;
  }
  .align-end {
    justify-content: flex-end;
  }
  .align-center {
    justify-content: center;
    text-align: center;
  }

  .glass-card {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 16px;
    padding: 3rem;
    max-width: 700px;
    width: 100%;
    color: white;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  h2 {
    font-size: 2.5rem;
    margin: 0.5rem 0 1.5rem 0;
    line-height: 1.1;
    font-weight: 800;
  }

  .carousel-wrapper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    gap: 1.5rem;
  }

  .gallery-track {
    flex-grow: 1;
    display: grid;
    place-items: center;
    touch-action: pan-y;
    overscroll-behavior-x: none;
    padding: 0 3rem;
    width: 100%;
  }

  .gallery-slide {
    grid-area: 1 / 1;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition:
      opacity 0.3s ease,
      transform 0.3s ease,
      visibility 0.3s;
  }

  .gallery-slide.active {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .image-frame {
    width: 100%;
    height: 45vh;
    min-height: 250px;
    max-height: 450px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .gallery-image {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain; /* Ensures images are never stretched or cropped */
    filter: drop-shadow(0 4px 10px rgba(0, 0, 0, 0.15));
  }

  .image-caption {
    font-size: 1rem;
    opacity: 0.8;
    margin: 1rem 0 0 0;
    font-weight: 500;
    text-align: center;
    height: 1.5rem;
  }

  .nav-btn {
    background: none;
    border: none;
    color: white;
    font-size: 2.8rem;
    cursor: pointer;
    opacity: 0.6;
    transition:
      opacity 0.2s,
      transform 0.2s;
    padding: 0 10px;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 20;
    -webkit-tap-highlight-color: transparent;
    user-select: none;
    outline: none;
  }

  .right-btn {
    right: 2%;
  }
  .left-btn {
    left: 2%;
  }

  @media (hover: hover) {
    .nav-btn:hover {
      opacity: 1;
      transform: translateY(-50%) scale(1.1);
    }
  }

  .nav-btn:active {
    opacity: 1;
    transform: translateY(-50%) scale(0.95);
  }

  .pagination-dots {
    display: flex;
    gap: 8px;
    margin-top: 1.5rem;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.3);
    border: none;
    cursor: pointer;
    transition:
      background-color 0.3s,
      transform 0.3s;
    padding: 0;
  }

  .dot.active {
    background-color: white;
    transform: scale(1.2);
  }

  @media (max-width: 768px) {
    .station {
      padding: 0 5%;
      justify-content: center;
    }
    .glass-card {
      padding: 2rem 1rem;
    }
    .nav-btn {
      font-size: 2rem;
      padding: 0 5px;
    }
    .gallery-track {
      padding: 0 1rem;
    }
    .image-frame {
      height: 35vh;
    }
  }
</style>

<script>
  function initImageCarousels() {
    const carousels = document.querySelectorAll(".gallery-container");

    carousels.forEach((carousel) => {
      if (carousel.dataset.initialized) return;
      carousel.dataset.initialized = "true";

      const slides = carousel.querySelectorAll(".gallery-slide");
      const dots = carousel.querySelectorAll(".dot");

      if (slides.length === 0) return;

      const rightBtn = carousel.querySelector(".right-btn");
      const leftBtn = carousel.querySelector(".left-btn");

      let currentIndex = 0;
      let isAnimating = false;
      const FADE_DURATION = 300;

      let autoPlayTimer;
      const AUTOPLAY_DELAY = 5000;

      function startAutoPlay() {
        stopAutoPlay();
        autoPlayTimer = setInterval(() => {
          showSlide(currentIndex + 1);
        }, AUTOPLAY_DELAY);
      }

      function stopAutoPlay() {
        clearInterval(autoPlayTimer);
      }

      let lastActionTime = 0;
      const COOLDOWN_MS = 800;

      function canInteract() {
        const currentTime = new Date().getTime();
        if (currentTime - lastActionTime > COOLDOWN_MS && !isAnimating) {
          lastActionTime = currentTime;
          return true;
        }
        return false;
      }

      function showSlide(index) {
        if (index === currentIndex) return;
        isAnimating = true;

        startAutoPlay();

        let nextIndex = index;
        if (nextIndex < 0) nextIndex = slides.length - 1;
        else if (nextIndex >= slides.length) nextIndex = 0;

        slides[currentIndex].classList.remove("active");
        if (dots[currentIndex]) dots[currentIndex].classList.remove("active");

        currentIndex = nextIndex;

        slides[currentIndex].classList.add("active");
        if (dots[currentIndex]) dots[currentIndex].classList.add("active");

        setTimeout(() => {
          isAnimating = false;
        }, FADE_DURATION);
      }

      carousel.addEventListener("mouseenter", stopAutoPlay);
      carousel.addEventListener("mouseleave", startAutoPlay);

      leftBtn?.addEventListener("click", () => {
        if (canInteract()) showSlide(currentIndex + 1);
      });

      rightBtn?.addEventListener("click", () => {
        if (canInteract()) showSlide(currentIndex - 1);
      });

      dots.forEach((dot, idx) => {
        dot.addEventListener("click", () => {
          if (canInteract()) showSlide(idx);
        });
      });

      let touchStartX = 0;
      let touchStartY = 0;

      carousel.addEventListener(
        "touchstart",
        (e) => {
          touchStartX = e.touches[0].screenX;
          touchStartY = e.touches[0].screenY;
          stopAutoPlay();
        },
        { passive: true },
      );

      carousel.addEventListener(
        "touchmove",
        (e) => {
          if (!touchStartX || !touchStartY) return;
          const deltaX = touchStartX - e.touches[0].screenX;
          const deltaY = touchStartY - e.touches[0].screenY;
          if (Math.abs(deltaX) > Math.abs(deltaY)) e.preventDefault();
        },
        { passive: false },
      );

      carousel.addEventListener(
        "touchend",
        (e) => {
          const deltaX = e.changedTouches[0].screenX - touchStartX;
          const deltaY = e.changedTouches[0].screenY - touchStartY;
          if (Math.abs(deltaX) > Math.abs(deltaY)) {
            if (Math.abs(deltaX) > 50 && canInteract()) {
              if (deltaX > 0) showSlide(currentIndex + 1);
              else showSlide(currentIndex - 1);
            }
          }
          touchStartX = 0;
          touchStartY = 0;
          startAutoPlay();
        },
        { passive: true },
      );

      carousel.addEventListener(
        "wheel",
        (e) => {
          if (Math.abs(e.deltaX) > Math.abs(e.deltaY)) {
            e.preventDefault();
            if (Math.abs(e.deltaX) > 20 && canInteract()) {
              if (e.deltaX > 0) showSlide(currentIndex - 1);
              else showSlide(currentIndex + 1);
            }
          }
        },
        { passive: false },
      );

      startAutoPlay();
    });
  }

  document.addEventListener("astro:page-load", initImageCarousels);
</script>
