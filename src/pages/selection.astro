---
import StationPage from '../layouts/Layout.astro';
import backgroundImg from '../assets/images/ground.jpg';

const pageTitle = "המונים";

const pageDescription = "הסבר מפורט של תהליך המיון והקבלה לתוכנית ארזים.";

const stations = [
  {
    type: "hero",
    title: "המיונים",
    text: "השלבים השונים במיון וקבלה לתוכנית",
  },
  {
    title: "יום מיונים מרוכז של שחקים",
    text: "מלש\"בים שחיל המודיעין סובר שמתאימים למסלול שחקים ייקבלו זימון ליום מיונים עד הצהריים.",
  },
  {
    title: "סדנת ארזים",
    text: "מי שיימצאו מתאימים לתוכנית ארזים, יקבלו זימון לסדנה האורכת יום שלם וכוללת חשיפה למסלול וכן מבחנים. ארזים ממיינים גם מלש\"בים עם פרופיל קרבי.",
  },
  {
    title: "ראיון מקצועי",
    text: "על מנת להמשיך ולבחון התאמה, ייארך ראיון קצר האורך כשעה.",
  },
  {
    title: "ראיון אישיותי",
    text: "ראיון נוסף שנועד להכיר לעומק את המועמד.",
  },
  {
    title: "שלבים אחרונים",
    text: "ראיון עם פסיגולוג, סיווג בטחוני, קבלה למסלול העתודה האקדמית הצה\"לית ולאוניברסיטה (מפורט למטה).",
  },
  {
    title: "קבלה למסלול העתודה האקדמית",
    text: "על מנת להיכנס למסלול העתודה, יש למלא את הטופס שמופיע באתר \"מתגייסים\" ולבחור ב3 מסלולי לימוד שרירותיים.\
    לאחר הקבלה לארזים, יש לעשות מבחן מקוון פשוט מטעם עתודה כדי לבחון ללימודים אקדמיים.\
    בנוסף, עתודה דורשים מעתודאים להיבחן בפסיכומטרי ומומלץ להירשם לבחינה בהקדם ולא לחכות לתשובות קבלה.",
  },
  {
    type: "link",
    title: "קבלה לאוניברסיטת תל אביב",
    text: "יש להירשם כסטודנטים מן המניין לתואר דו-חוגי במתמטיקה ומדעי המחשב.",
    align: "center",
    links: [
      { text: "מסלול מדעי המחשב", url: "https://go.tau.ac.il/he/exact/ba/computer" },
      { text: "מסלול מתמטיקה", url: "https://go.tau.ac.il/he/exact/ba/math" }
    ]
  },
];
---

<StationPage 
  title={pageTitle}
  description={pageDescription}
  backgroundImage={backgroundImg}
  stations={stations} 
/>