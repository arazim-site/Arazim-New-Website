---
import StationPage from '../layouts/Layout.astro';
import backgroundImg from '../assets/images/bush.jpg';

const pageDescription = "תוכנית ארזים היא תוכנית שמטרתה להכשיר את מיטב הצעירים בתחומי המתמטיקה והסייבר ולשבצם ביחידות המקצועיות והמסווגות ביותר."

const baseUrl = import.meta.env.BASE_URL;
const cleanBaseUrl = baseUrl.endsWith('/') ? baseUrl.slice(0, -1) : baseUrl;

const stations = [
  {
    type: "hero",
    title: "תוכנית ארזים",
    text: "הופכים את הבלתי אפשרי לקשה מאוד",
  },
  {
    type: "standard",
    title: "מי אנחנו",
    text: "תוכנית ארזים הינה תוכנית מצוינות של חיל המודיעין וחיל התקשוב לפיתוח מנהיגות מקצועית ביחידות נבחרות העוסקות בתחומי המתמטיקה והטכנולוגיה. לתוכנית מגויסים מיטב הצעירים המבטיחים ביותר בתחומי העיסוק, במטרה להכשירם כך שיהוו דמויות מובילות ביחידות שאליהן הם מיועדים. במהלך ההכשרה בתוכנית החניכים משלימים תואר ראשון דו-חוגי במתמטיקה ובמדעי המחשב באוניברסיטת תל אביב בהיקף מלא, תוך שנתיים בלבד. עם סיום התואר משתבצים החניכים לשירות משמעותי ביחידה 8200 ובחטיבת ההגנה בסייבר. לתוכנית מתקבלים מדי שנה בין 10 ל-20 החניכים, וגודלה הקטן מאפשר לסגל התכנית לתת חניכה אישית ומדויקת.",
    align: "center"
  },
  {
    type: "cards",
    "mainTitle": "צירי ההכשרה",
    "cards": [
      {
        "icon": cleanBaseUrl + "/axes/academic.svg", 
        "title": "הציר האקדמי",
        "description": "התוכנית דורשת מצויינות אקדמית כתנאי בסיס, ובאופן עקבי חניכי ארזים מקבלים אותות הצטיינות מטעם האוניברסיטה.\
 מאחר והחניכים מסיימים את התואר בשנתיים בלבד, על החניכים לקחת מספר גדול של קורסים ולנהל לעצמם את הזמן בצורה מיטבית.\
 התוכנית מעודדת את חניכיה להתעמק בחומר האקדמי מעבר למסגרת התואר ואף לעשות מחקר אקדמי במקביל לתואר עבור אלו שזה רלוונטי להם."
      },
      {
        "icon": cleanBaseUrl + "/axes/professional.svg",
        "title": "הציר המקצועי",
        "description": "התוכנית משלבת בזמן התואר הכשרה מקצועית שמטרתה להכין את החניכים לקראת שירותם הצבאי.\
 החניכים עוברים הרצאות, מערכים ומקבלים אתגרים על בסיס שבועי, כך שבסוף השנתיים החניכים צוברים ידע נרחב לקראת השירות.\
 בנוסף, בתקופות הקיצים החניכים עוברים סדנאות ממוקדות ואינטנסיביות, וכן בסיום התואר ולפני הכניסה לתפקיד עוברים קורסים והכשרות מותאמות שיבוץ."
      },
      {
        "icon": cleanBaseUrl + "/axes/leadership.svg",
        "title": "הציר המנהיגותי",
        "description": "התוכנית מצפה מחניכיה להיות מנהיגים ומובילים, בין אם על ידי פיקוד ביחידות בהן משתבצים ובין אם על ידי הובלת שינויים טכנולוגיים כמוקדי ידע מנוסים.\
 לאורך התוכנית עוברים החניכים תכנים שמטרתם פיתוח בציר האישיותי, וכן התנסויות כמנהיגים ומפקדים.\
 בנוסף, בסיום התוכנית יוצאים הבוגרים לקורס קצינים, על מנת לקבל כלים להובלה ולשירות משמעותי."
      }
    ]
  },
  {
    type: "standard",
    title: "לימודים קודמים וארזים 2",
    text: "התוכנית מתאימה גם למועמדים אשר התחילו את התואר שלהם (באוניברסיטת תל אביב או מוסד לימודים אקדמי אחר) ואף כאלו שהשלימו את רובו. מועמדים שסיימו את התואר הראשון במהלך התיכון או בדחיית שירות יכולים להתמיין לתוכנית \"ארזים 2\", בה החניכים עושים תואר שני במדעי המחשב או במתמטיקה באוניברסיטת תל אביב בשנה אחת, ובמהלכה עוברים הכשרה מקצועית יחד עם תוכנית \"ארזים\", ולאחר מכן משרתים איתם ביחידות. המיונים ל\"ארזים 2\" נפרדים לחיל מודיעין וחיל תקשוב וניתן לעשות את שניהם.",
    align: "center"
  },
];
---

<StationPage 
  description={pageDescription}
  backgroundImage={backgroundImg}
  stations={stations} 
/>