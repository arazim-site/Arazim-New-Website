---
import StationPage from '../layouts/Layout.astro';
import backgroundImg from '../assets/images/road.jpg';

const pageTitle = "המסלול";

const pageDescription = "הסבר מפורט של תהליך ההכשרה בתוכנית ארזים.";

const stations = [
  {
    type: "hero",
    id: "00",
    title: "המסלול",
    text: "התחנות המרכזיות במסלול של ארזים",
  },
  {
    type: "step",
    id: "01",
    duration: "חודש וחצי",
    title: "סדנת הכנה לאקדמיה (קיץ 0)",
    text: "במהלך הסדנה מקבלים כלים לקראת הלימודים באקדמיה. הסדנה כוללת קורס אקדמי ראשון, תכנים על ניהול זמנים, עמידה בלחץ, מיומנויות למידה ומסוגלות. בנוסף, במהלך הסדנה רוכשים בסיס טכנולוגי שישרת את החניכים למשך השנה. במהלך הסדנה מתגבשים חברי המחזור יחד עם הרבה פעילויות חברתיות.",
    align: "start"
  },
  {
    type: "step",
    id: "02",
    duration: "עשרה חודשים",
    title: "שנה א'",
    text: "במהלך השנה הראשונה החניכים לוקחים בערך מחצית מכמות הנקודות הנדרשות על מנת להשלים את התואר. בנוסף, החניכים נדרשים ללמוד תכנים מקצועיים אותם התוכנית מספקת, ומקבלים תשומת לב פרטנית עם פגישות אישיות עם מפקד המחזור שלהם. מעבר לכך, החניכים לוקחים חלק בפרוייקטים וחווים עבודה והתנהלות בצוות.",
    align: "end"
  },
  {
    type: "step",
    id: "03",
    duration: "חודשיים",
    title: "סדנה מקצועית (קיץ 1)",
    text: "סדנה מקצועית העוברת במתכונת קורס צבאי בבסיס סגור, שבמהלכה החניכים עוברים תכנים מסווגים ונחשפים לעשייה באגף המודיעין ובחטיבת ההגנה בסייבר. הסדנה היא אינטנסיבית מטבעה ומעבר לחומר המועבר במהלכה, נמדדת התאמתם של החניכים לתפקידים השונים של ארזים על מנת להבטיח שיבוץ אופטימלי של כל חניך לתפקיד שמתאים עבורו. השיבוצים נקבעים בסיום סדנת הקיץ.",
    align: "start"
  },
  {
    type: "step",
    id: "04",
    duration: "עשרה חודשים",
    title: "שנה ב'",
    text: "במהלך השנה השנייה החניכים מסיימים את התואר. מעבר לכך, החניכים לוקחים חלק בסמינר מנהיגות.",
    align: "center"
  },
  {
    type: "step",
    id: "05",
    duration: "חודש",
    title: "טירונות",
    text: "ארזים עוברים טירונות 02 המותאמת לחיילים עורפיים.",
    align: "start"
  },
  {
    type: "step",
    id: "06",
    duration: "שבועיים",
    title: "סדנת פיקוד (קיץ 2)",
    text: "לפני היציאה לקורס קצינים, החניכים עוברים סדנה מטעם ארזים שמטרתה להכין אותם לקראת הקורס ולהכשיר אותם בפיקוד והובלה.",
    align: "end"
  },
  {
    type: "step",
    id: "07",
    duration: "שישה חודשים",
    title: "קורס קצינים",
    text: "הקורס אורך 3 חודשים בבה\"ד 1 וארזים עושים אותו במגמת נחשון. לאחר סיום הקורס יש 3 חודשים נוספים של השלמה חילית.",
    align: "center"
  },
  {
    type: "step",
    id: "08",
    duration: "שלושה-שמונה חודשים",
    title: "הכשרה מתקדמת ביחידה",
    text: "עם ההגעה ליחידה, הבוגרים עוברים הכשרה ממוקדת לתפקיד ביחידה או במסגרת קורס ייעודי, כתלות בשיבוץ.",
    align: "center"
  },
  {
    type: "step",
    id: "09",
    duration: "ארבע שנים",
    title: "השירות הצבאי",
    text: "לאחר תקופת חפיפה, מתחילים בתפקיד הראשון כחברי צוות בהתאם לשיבוץ. בהמשך, יכולים הבוגרים לעשות תפקידי פיקוד כראשי צוותים ביחידות או כסגל ארזים.",
    align: "start"
  }
];
---

<StationPage 
  title={pageTitle}
  description={pageDescription}
  backgroundImage={backgroundImg}
  stations={stations} 
/>